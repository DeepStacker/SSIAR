ssiar.duckdns.org {
    root * /var/www/ssiar/dist

    # API routes → backend (must come before SPA handler)
    handle /api/* {
        reverse_proxy localhost:8000
    }

    # SPA fallback — serve index.html for non-file paths
    handle {
        try_files {path} /index.html
        file_server
    }

    # Static assets with hash-based filenames → cache forever
    @static {
        path *.svg *.woff2 *.woff *.ttf *.eot *.css *.js *.png *.jpg *.ico
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
    encode @static gzip

    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options "nosniff"
    }
}
