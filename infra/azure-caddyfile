ssiar.duckdns.org {
    root * /var/www/ssiar/dist

    # API and SSE routes → backend
    reverse_proxy /api/* localhost:8000

    # Static assets with hash-based filenames → cache forever
    @static {
        path *.svg *.woff2 *.woff *.ttf *.eot *.css *.js *.png *.jpg *.ico
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
    encode @static gzip

    # SPA fallback — serve index.html for non-file, non-API paths
    handle {
        try_files {path} /index.html
        file_server
    }

    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options "nosniff"
    }
}
